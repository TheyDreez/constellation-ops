# ─── Supabase ─────────────────────────────────────────────────
# Pega esses valores em: https://supabase.com/dashboard → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ─── Resend (emails) ──────────────────────────────────────────
# Pega em: https://resend.com → API Keys
RESEND_API_KEY=re_sua_key_aqui
RESEND_FROM_EMAIL=helpdesk@suaempresa.com.br

# ─── Gemini (chatbot) ─────────────────────────────────────────
# Pega em: https://aistudio.google.com/apikey
GEMINI_API_KEY=sua_gemini_key_aqui

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
